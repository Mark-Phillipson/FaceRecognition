@page "/group-enroll"
@using FaceRecognition.Client.Models
@inject FaceRecognition.Client.Services.IFaceService FaceService
@inject FaceRecognition.Client.Services.IIndexedDbService IndexedDb
@inject FaceRecognition.Client.Services.IRecognitionService RecognitionService

<h3>Group Photo Enroll</h3>

<p>Upload a photo containing multiple people. The app will detect faces, crop thumbnails, and let you assign names.</p>

<InputFile OnChange="OnInputFileChange" />

@if (isProcessing)
{
    <div class="mt-2">
        <div class="progress" style="height:24px;">
            <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width:@progressPercent%">@progressPercent%</div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(originalPreview))
{
    <div class="mt-3">
        <img src="@originalPreview" alt="original" style="max-width:480px;max-height:480px;" />
    </div>
}

@if (detections != null && detections.Count > 0)
{
    <h4 class="mt-3">Detected Faces (@detections.Count)</h4>
    <div class="row">
        @for (int i = 0; i < detections.Count; i++)
        {
            var idx = i;
            var d = detections[idx];
            <div class="col-6 col-md-3 mb-3">
                <div class="card text-center">
                    <!-- show thumbnail at its actual size (max constrained by card) to avoid blurring -->
                    <img src="@d.ThumbnailDataUrl" style="max-width:100%;height:auto;display:block;margin:12px auto 0;" />
                    <div class="card-body">
                        @if (suggestions != null && suggestions.Count > idx && suggestions[idx] != null && suggestions[idx].Count > 0)
                        {
                            <div><strong>Suggested:</strong></div>
                            @foreach (var s in suggestions[idx].Take(3))
                            {
                                <div class="d-flex align-items-center mb-1">
                                    <span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:@GetConfidenceColor(s.Distance);margin-right:8px;"></span>
                                    @if (!string.IsNullOrEmpty(s.ImageDataUrl))
                                    {
                                        <img src="@s.ImageDataUrl" style="width:32px;height:32px;object-fit:cover;margin-right:8px;" />
                                    }
                                    <div>
                                        <div>@s.PersonName</div>
                                        <div class="small text-muted">Distance: @s.Distance:F3</div>
                                    </div>
                                    <button class="btn btn-sm btn-outline-primary ms-auto" @onclick="(() => AssignSuggested(idx, s.PersonId, s.PersonName))">Assign</button>
                                </div>
                            }
                        }
                        <div class="mb-2">
                            <label class="form-label">Assign name</label>
                            <input type="text" class="form-control" value="@assignNames[idx]" @oninput="@(e => OnAssignNameInput(idx, e))" placeholder="Type name or pick suggested" />
                        </div>
                        <div class="d-flex">
                            <button class="btn btn-primary me-2" @onclick="(() => SaveAssignment(idx))">Save</button>
                            <button class="btn btn-secondary" @onclick="(() => Skip(idx))">Skip</button>
                        </div>
                        @if (!string.IsNullOrEmpty(detectStatus[idx]))
                        {
                            <div class="mt-2 small text-success">@detectStatus[idx]</div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private string originalPreview = string.Empty;
    private List<FaceDetectionResult>? detections;
    private List<List<MatchResult>>? suggestions;
    private List<string> assignNames = new();
    private List<string> detectStatus = new();
    private bool isProcessing = false;
    private int progressPercent = 0;
    private System.Threading.CancellationTokenSource? progressCts;

    private async Task StartProgressAsync(System.Threading.CancellationToken token)
    {
        var rnd = new Random();
        try
        {
            while (!token.IsCancellationRequested)
            {
                await Task.Delay(250, token);
                if (progressPercent < 90)
                {
                    progressPercent = Math.Min(90, progressPercent + rnd.Next(3, 8));
                }
                else if (progressPercent < 95)
                {
                    progressPercent++;
                }
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
            // expected when cancelled
        }
    }

    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        var file = e.File;
        using var ms = new MemoryStream();
        await file.OpenReadStream(20 * 1024 * 1024).CopyToAsync(ms);
        originalPreview = $"data:{file.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
        detections = null;
        suggestions = null;
        assignNames.Clear();
        detectStatus.Clear();

        // start progress indicator
        progressCts?.Cancel();
        progressCts = new System.Threading.CancellationTokenSource();
        isProcessing = true;
        progressPercent = 0;
        _ = StartProgressAsync(progressCts.Token);

            try
        {
            await FaceService.LoadModelsAsync("/models");
            // request no downscaling (0 = no scaling) so thumbnails are produced at crop size
            var dets = await FaceService.DetectMultipleFacesEmbeddingAsync(originalPreview, 0);
            detections = dets ?? new List<FaceDetectionResult>();
            // initialize arrays
            assignNames = Enumerable.Range(0, detections.Count).Select(_ => string.Empty).ToList();
            detectStatus = Enumerable.Range(0, detections.Count).Select(_ => string.Empty).ToList();

            // compute suggestions for each detection (non-blocking)
            suggestions = new List<List<MatchResult>>();
            for (int i = 0; i < detections.Count; i++)
            {
                var du = detections[i];
                var s = await RecognitionService.FindMatchesAsync(du.Descriptor, 5);
                suggestions.Add(s);
                if (s != null && s.Count > 0)
                {
                    // Only set the suggested name if the user hasn't already entered one
                    if (string.IsNullOrWhiteSpace(assignNames[i]))
                    {
                        assignNames[i] = s[0].PersonName;
                    }
                }
            }
        }
        catch (Exception ex)
        {
            detections = new List<FaceDetectionResult>();
        }
        finally
        {
            // finish progress
            if (progressCts != null)
            {
                progressCts.Cancel();
            }
            progressPercent = 100;
            await Task.Delay(300);
            isProcessing = false;
            progressPercent = 0;
            progressCts = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task AssignSuggested(int index, string personId, string personName)
    {
        assignNames[index] = personName;
        await SaveAssignment(index, personIdOverride: personId);
    }

    private async Task SaveAssignment(int index, string? personIdOverride = null)
    {
        if (detections == null || index < 0 || index >= detections.Count) return;
        var d = detections[index];
        var name = assignNames[index]?.Trim();
        if (string.IsNullOrEmpty(name) && string.IsNullOrEmpty(personIdOverride))
        {
            detectStatus[index] = "Please enter a name or choose a suggestion.";
            return;
        }

        // find or create person (avoid duplicate person names)
        string personId = personIdOverride ?? string.Empty;
        if (string.IsNullOrEmpty(personId))
        {
            // check for existing person with same name (case-insensitive)
            var people = await IndexedDb.GetAllAsync<Person>("persons");
            var existing = people?.FirstOrDefault(p => string.Equals(p.Name?.Trim(), name, StringComparison.OrdinalIgnoreCase));
            if (existing != null)
            {
                personId = existing.Id;
                detectStatus[index] = $"Assigned to existing person '{existing.Name}'";
            }
            else
            {
                var p = new Person { Name = name! };
                await IndexedDb.PutAsync("persons", p);
                personId = p.Id;
            }
        }

        // save thumbnail as a FaceImage and embedding
        var image = new FaceImage { PersonId = personId, DataUri = d.ThumbnailDataUrl ?? string.Empty };
        await IndexedDb.PutAsync("images", image);
        var embedding = new FaceEmbedding { PersonId = personId, ImageId = image.Id, Embedding = d.Descriptor };
        await IndexedDb.PutAsync("embeddings", embedding);

        detectStatus[index] = "Saved.";
    }

    private Task Skip(int index)
    {
        detectStatus[index] = "Skipped.";
        return Task.CompletedTask;
    }

    private void OnAssignNameInput(int index, ChangeEventArgs e)
    {
        if (index < 0 || detections == null || index >= detections.Count) return;
        assignNames[index] = e?.Value?.ToString() ?? string.Empty;
    }

    private string GetConfidenceColor(double distance)
    {
        // thresholds: <=0.45 green, <=0.6 yellow, >0.6 red
        if (distance <= 0.45) return "#28a745"; // green
        if (distance <= 0.6) return "#ffc107"; // yellow
        return "#dc3545"; // red
    }
}
